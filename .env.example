# Copy to .env.local and fill in values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=   # service_role key — server only, never expose to the client

# BayarCash (payments)
BAYARCASH_API_TOKEN=
BAYARCASH_PORTAL_KEY=
BAYARCASH_SECRET_KEY=

# Meta WhatsApp Cloud API (WABA + student OTP delivery)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="cikgurohani <no-reply@cikgurohani.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
